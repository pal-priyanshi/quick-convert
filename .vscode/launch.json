{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "asv training",
            "type": "debugpy",
            "request": "launch",
            "module": "quick_convert.cli.train_asv",
            "args": [
                "+asv.overrides.batch_size=32",
            ],
            "console": "integratedTerminal",
            "python": ".venv/bin/python",
            "justMyCode": false,
            "env": {
                "CUDA_VISIBLE_DEVICES": "1"
            }
        },
        {
            "name": "anonymize",
            "type": "debugpy",
            "request": "launch",
            "module": "quick_convert.cli.anonymize",
            "args": [
                "--config-name",
                "run/anonymize_emotion_compensation_iemocap",
                "dataset=stutter",
            ],
            "console": "integratedTerminal",
            "python": ".venv/bin/python",
            "justMyCode": false,
            "env": {
                "CUDA_VISIBLE_DEVICES": "1"
            }
        },
        {
            "name": "eval asv",
            "type": "debugpy",
            "request": "launch",
            "module": "quick_convert.cli.eval_asv",
            "args": [
                "+asv.overrides.batch_size=32",
            ],
            "console": "integratedTerminal",
            "python": ".venv/bin/python",
            "justMyCode": false,
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            }
        },
        {
            "name": "anonymize emocomp test",
            "type": "debugpy",
            "request": "launch",
            "module": "quick_convert.cli.anonymize",
            "args": [
                "--config-name",
                "run/anonymize_emocomp_clac",
            ],
            "console": "integratedTerminal",
            "python": ".venv/bin/python",
            "justMyCode": false,
            "env": {
                "CUDA_VISIBLE_DEVICES": "0",
                "HYDRA_FULL_ERROR": "1"
            }
        }
    ]
}